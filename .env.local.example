# 노션 API 설정 (F010)
# 노션 통합(Integration) 생성: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 견적서를 관리하는 노션 데이터베이스 ID
# 데이터베이스 URL에서 추출: https://notion.so/{workspace}/{database_id}?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 사이트 URL (OG 메타데이터, sitemap, robots.txt에 사용)
# 로컬 개발: http://localhost:3000
# 프로덕션: Vercel 배포 URL (예: https://your-project.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 관리자 로그인 비밀번호
ADMIN_PASSWORD=your_secure_password

# 세션 쿠키 서명에 사용하는 비밀 키 (최소 32자 이상의 랜덤 문자열)
# 생성 예시: openssl rand -hex 32
AUTH_SECRET=your_random_secret_string_min_32_chars